{
  "manifest_version": 3,
  "name": "bing2fa",
  "version": "1.0.2",
  "description": "Autofill Binghamton University 2fa",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://cas.cc.binghamton.edu/cas/login?*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://cas.cc.binghamton.edu/cas/login?*"
      ],
      "js": [
        "totp.js",
        "content.js"
      ]
    },
    {
      "matches": [
        "https://password.binghamton.edu/loggedin"
      ],
      "js": [
        "totp.js",
        "set2fa.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "32": "icon32.png",
    "64": "icon64.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bing2fa@jsousou77",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
